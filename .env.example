# ---- Database (Postgres) ----
POSTGRES_USER=jugasaro
POSTGRES_PASSWORD=jugasaro_dev
POSTGRES_DB=jugasaro
POSTGRES_PORT=5434

# Used by Prisma in apps/api
DATABASE_URL=postgresql://jugasaro:jugasaro_dev@localhost:5434/jugasaro?schema=public

# ---- API (NestJS) ----
API_PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=change_me_in_prod_please_at_least_32_chars_long
JWT_EXPIRES_IN=7d
COOKIE_DOMAIN=localhost

# CORS — comma-separated origins allowed to hit the API
CORS_ORIGINS=http://localhost:3000

# ---- Web (Next.js) ----
WEB_PORT=3000
# Public URL of the API as seen by the browser
NEXT_PUBLIC_API_URL=http://localhost:4000
# Server-side URL of the API (used by Server Components / Server Actions)
API_INTERNAL_URL=http://localhost:4000
